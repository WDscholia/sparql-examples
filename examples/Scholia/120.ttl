@prefix q: <https://bigcat-um.github.io/sparql-examples/Scholia/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix scholia: <http://scholia.toolforge.org/ns/> .
@prefix scholiaAspect: <http://scholia.toolforge.org/ns/aspect/> .
@prefix scholiaView: <http://scholia.toolforge.org/ns/view/> .
@prefix wd: <http://wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix spex: <https://purl.expasy.org/sparql-examples/ontology#> .
@prefix wikibase: <http://wikiba.se/ontology#> .
@prefix cito: <http://purl.org/spar/cito/> .

q:120 a sh:SPARQLExecutable,
  sh:SPARQLSelectExecutable;
  sh:prefixes _:sparql_examples_prefixes ;
  sh:select '''# Recent publications by people associated with event
PREFIX target: <http://www.wikidata.org/entity/{{ q }}>
PREFIX bd: <http://www.bigdata.com/rdf#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
SELECT ?publication_date ?work ?workLabel ?authors ?authorsUrl WHERE {
  {
    SELECT (xsd:date(MAX(?publication_datetime)) AS ?publication_date) ?work (GROUP_CONCAT(DISTINCT ?person_label; SEPARATOR=", ") AS ?authors) (CONCAT("../authors/", GROUP_CONCAT(DISTINCT SUBSTR(STR(?person),32); SEPARATOR=",")) AS ?authorsUrl) WHERE {
      {
        SELECT DISTINCT ?person WHERE {
          {
            # speaker, organizer, program committe member 
            target: wdt:P823 | wdt:P664 | wdt:P5804 ?person .
          }
          UNION {
            # participant
            ?person wdt:P1344 | ^wdt:P710 target: .
          }
          UNION {
            # author
            ?person ^wdt:P50/wdt:P1433/wdt:P4745 target: .
          }
          UNION {
            # editor of proceedings
            ?person ^wdt:P98/wdt:P4745 target: .
          }
        }
      } .
      ?work wdt:P50 ?person ;
            wdt:P577 ?publication_datetime .
      ?person rdfs:label ?person_label . FILTER (LANG(?person_label) = 'en')
    }
    GROUP BY ?work
  }
}
ORDER BY DESC(?publication_date)
LIMIT 500
''';
  scholia:aspect scholiaAspect:Event ;
  scholia:defaultView scholiaView: ;
  rdfs:comment "Event aspect: no description given"@en ;
  schema:target <https://qlever.dev/wikidata> ;
  cito:usesMethodIn <https://github.com/WDscholia/scholia/tree/master/scholia/app/templates/event_recent-publications.sparql> ;
  dcterms:license <https://www.gnu.org/licenses/gpl-3.0> .