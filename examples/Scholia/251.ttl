@prefix q: <https://bigcat-um.github.io/sparql-examples/Scholia/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix scholia: <http://scholia.toolforge.org/ns/> .
@prefix scholiaAspect: <http://scholia.toolforge.org/ns/aspect/> .
@prefix scholiaView: <http://scholia.toolforge.org/ns/view/> .
@prefix wd: <http://wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix spex: <https://purl.expasy.org/sparql-examples/ontology#> .
@prefix wikibase: <http://wikiba.se/ontology#> .
@prefix cito: <http://purl.org/spar/cito/> .

q:251 a sh:SPARQLExecutable,
  sh:SPARQLSelectExecutable;
  sh:prefixes _:sparql_examples_prefixes ;
  sh:select '''
PREFIX target: <http://www.wikidata.org/entity/{{ q }}>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
SELECT (?child_ AS ?child) ?childLabel ?rgb (?parent_ AS ?parent) ?parentLabel WHERE {
  {
    # Parent taxa
    target: wdt:P171* ?child_ .
    ?child_ wdt:P171 ?parent_ .
    BIND ("FFFFFF" AS ?rgb)
  } UNION {
    # Child taxa
    {SELECT ?child_ ?parent_ WHERE {
      BIND (target: AS ?parent_) .
      ?child_ wdt:P171 ?parent_ .
    } LIMIT 100}
    BIND ("DDDDDD" AS ?rgb)
  } UNION {
    BIND (target: AS ?child_) .
    ?child_ wdt:P171 ?parent_ .
    BIND ("FF0000" AS ?rgb)
  }

  OPTIONAL {
    ?child_ wdt:P105 ?child_rank_ .
  }
  OPTIONAL {
    ?parent_ wdt:P105 ?parent_rank_ .
  }

  BIND (CONCAT(?child_Label, " - ", COALESCE(?child_rank_Label, "???")) AS ?childLabel)
  BIND (CONCAT(?parent_Label, " - ", COALESCE(?parent_rank_Label, "???")) AS ?parentLabel)
}
''';
  scholia:aspect scholiaAspect:Taxon ;
  scholia:defaultView scholiaView:Graph ;
  rdfs:comment "Taxon aspect: no description given"@en ;
  schema:target <https://qlever.dev/wikidata> ;
  cito:usesMethodIn <https://github.com/WDscholia/scholia/tree/master/scholia/app/templates/taxon_tree_REMOTE_3624679.sparql> ;
  dcterms:license <https://www.gnu.org/licenses/gpl-3.0> .