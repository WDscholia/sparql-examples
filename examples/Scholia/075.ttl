@prefix q: <https://bigcat-um.github.io/sparql-examples/Scholia/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix scholia: <http://scholia.toolforge.org/ns/> .
@prefix scholiaAspect: <http://scholia.toolforge.org/ns/aspect/> .
@prefix scholiaView: <http://scholia.toolforge.org/ns/view/> .
@prefix wd: <http://wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix spex: <https://purl.expasy.org/sparql-examples/ontology#> .
@prefix wikibase: <http://wikiba.se/ontology#> .
@prefix cito: <http://purl.org/spar/cito/> .

q:075 a sh:SPARQLExecutable,
  sh:SPARQLSelectExecutable;
  sh:prefixes _:sparql_examples_prefixes ;
  sh:select '''PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
SELECT ?count ?description WHERE {
  {
    {
      SELECT (COUNT(*) AS ?count) WHERE {
        [] wdt:P31 wd:Q30612 .
      }
    }
    BIND ("Number of clinical trials" AS ?description)
  }
  UNION {
    {
      SELECT (COUNT(*) AS ?count) WHERE {
        [] wdt:P3098 [] .
      }
    }
    BIND ("Links to ClinicalTrials.gov" AS ?description)
  }
  UNION {
    {
      SELECT (COUNT(*) AS ?count) WHERE {
        [] wdt:P6099 [] .
      }
    }
    BIND ("Number of clinical trial phases links" AS ?description)
  }
  UNION {
    {
      SELECT (COUNT(*) AS ?count) WHERE {
        [] wdt:P6220 [] .
      }
    }
    BIND ("Links to OpenTrials" AS ?description)
  }
}
ORDER BY DESC(?count)
''';
  scholia:aspect scholiaAspect:Clinical-trial-index ;
  scholia:defaultView scholiaView: ;
  rdfs:comment "Clinical-trial-index aspect: no description given"@en ;
  schema:target <https://qlever.dev/wikidata> ;
  cito:usesMethodIn <https://github.com/WDscholia/scholia/tree/master/scholia/app/templates/clinical-trial-index_statistics.sparql> ;
  dcterms:license <https://www.gnu.org/licenses/gpl-3.0> .