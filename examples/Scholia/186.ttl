@prefix q: <https://bigcat-um.github.io/sparql-examples/Scholia/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix scholia: <http://scholia.toolforge.org/ns/> .
@prefix scholiaAspect: <http://scholia.toolforge.org/ns/aspect/> .
@prefix scholiaView: <http://scholia.toolforge.org/ns/view/> .
@prefix wd: <http://wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix spex: <https://purl.expasy.org/sparql-examples/ontology#> .
@prefix wikibase: <http://wikiba.se/ontology#> .
@prefix cito: <http://purl.org/spar/cito/> .

q:186 a sh:SPARQLExecutable,
  sh:SPARQLSelectExecutable;
  sh:prefixes _:sparql_examples_prefixes ;
  sh:select '''PREFIX target: <http://www.wikidata.org/entity/{{ q }}>
PREFIX bd: <http://www.bigdata.com/rdf#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
SELECT ?publication_date ?episode ?episodeLabel (CONCAT("/podcast-episode/", SUBSTR(STR(?episode),32)) AS ?episodeUrl) WHERE {
  {
    SELECT DISTINCT ?episode (MIN(?publication_date_) AS ?publication_date) WHERE {
      ?episode wdt:P31 wd:Q61855877 ;
               wdt:P179 target: .
      OPTIONAL {
        ?episode wdt:P577 ?publication_datetime .
        BIND (xsd:date(?publication_datetime) AS ?publication_date_)
      }
    }
    GROUP BY ?episode
    ORDER BY DESC(?publication_date)
    LIMIT 50
  }
}
GROUP BY ?publication_date ?episode ?episodeLabel
ORDER BY DESC(?publication_date)
''';
  scholia:aspect scholiaAspect:Podcast ;
  scholia:defaultView scholiaView: ;
  rdfs:comment "Podcast aspect: no description given"@en ;
  schema:target <https://qlever.dev/wikidata> ;
  cito:usesMethodIn <https://github.com/WDscholia/scholia/tree/master/scholia/app/templates/podcast_recent-episodes.sparql> ;
  dcterms:license <https://www.gnu.org/licenses/gpl-3.0> .