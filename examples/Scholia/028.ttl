@prefix q: <https://bigcat-um.github.io/sparql-examples/Scholia/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix scholia: <http://scholia.toolforge.org/ns/> .
@prefix scholiaAspect: <http://scholia.toolforge.org/ns/aspect/> .
@prefix scholiaView: <http://scholia.toolforge.org/ns/view/> .
@prefix wd: <http://wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix spex: <https://purl.expasy.org/sparql-examples/ontology#> .
@prefix wikibase: <http://wikiba.se/ontology#> .
@prefix cito: <http://purl.org/spar/cito/> .

q:028 a sh:SPARQLExecutable,
  sh:SPARQLSelectExecutable;
  sh:prefixes _:sparql_examples_prefixes ;
  sh:select '''PREFIX gas: <http://www.bigdata.com/rdf/gas#>
PREFIX bd: <http://www.bigdata.com/rdf#>
PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
SELECT ?author ?workLabel WHERE {
  {
    SELECT ?work ?author WHERE {
      {}
      {% for q1 in qs %}
      {% for q2 in qs %}
      {% if q1 < q2 %}
      UNION {
        SERVICE <https://query.wikidata.org/sparql> {
          SELECT ?work ?author WHERE {
            SERVICE gas:service {
              gas:program gas:gasClass "com.bigdata.rdf.graph.analytics.BFS" ;
                          gas:in wd:{{ q1 }} ;
                          gas:target wd:{{ q2 }} ;
                          gas:traversalDirection "Undirected" ;
                          gas:out ?work ;
                          gas:linkType wdt:P50 ;
                          gas:maxVisited 5000 .
            }
            ?work wdt:P50 ?author
          }
        }
      } # UNION END
      {% endif %}
      {% endfor %}
      {% endfor %}
    }
  }
}
''';
  scholia:aspect scholiaAspect:Authors ;
  scholia:defaultView scholiaView:Graph ;
  rdfs:comment "Authors aspect: no description given"@en ;
  schema:target <https://qlever.dev/wikidata> ;
  cito:usesMethodIn <https://github.com/WDscholia/scholia/tree/master/scholia/app/templates/authors_co-author.sparql> ;
  dcterms:license <https://www.gnu.org/licenses/gpl-3.0> .