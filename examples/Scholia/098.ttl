@prefix q: <https://bigcat-um.github.io/sparql-examples/Scholia/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix scholia: <http://scholia.toolforge.org/ns/> .
@prefix scholiaAspect: <http://scholia.toolforge.org/ns/aspect/> .
@prefix scholiaView: <http://scholia.toolforge.org/ns/view/> .
@prefix wd: <http://wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix spex: <https://purl.expasy.org/sparql-examples/ontology#> .
@prefix wikibase: <http://wikiba.se/ontology#> .
@prefix cito: <http://purl.org/spar/cito/> .

q:098 a sh:SPARQLExecutable,
  sh:SPARQLSelectExecutable;
  sh:prefixes _:sparql_examples_prefixes ;
  sh:select '''PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
SELECT DISTINCT ?start_date ?trial ?trialLabel ?intervention ?interventionLabel ?sponsor ?sponsorLabel WHERE {
  ?trial wdt:P31 wd:Q30612 ;
         wdt:P1050/wdt:P279* wd:{{ q }} .
  OPTIONAL {
    ?trial wdt:P580 ?starttime
    BIND (SUBSTR(STR(?starttime),0,11) AS ?start_date)
  }
  OPTIONAL {
    ?trial wdt:P4844 ?intervention
  }
  OPTIONAL {
    ?trial wdt:P859 ?sponsor
  }
}
ORDER BY DESC(?starttime)
''';
  scholia:aspect scholiaAspect:Disease ;
  scholia:defaultView scholiaView: ;
  rdfs:comment "Disease aspect: no description given"@en ;
  schema:target <https://qlever.dev/wikidata> ;
  cito:usesMethodIn <https://github.com/WDscholia/scholia/tree/master/scholia/app/templates/disease_clinical-trials.sparql> ;
  dcterms:license <https://www.gnu.org/licenses/gpl-3.0> .