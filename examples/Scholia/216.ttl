@prefix q: <https://bigcat-um.github.io/sparql-examples/Scholia/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix scholia: <http://scholia.toolforge.org/ns/> .
@prefix scholiaAspect: <http://scholia.toolforge.org/ns/aspect/> .
@prefix scholiaView: <http://scholia.toolforge.org/ns/view/> .
@prefix wd: <http://wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix spex: <https://purl.expasy.org/sparql-examples/ontology#> .
@prefix wikibase: <http://wikiba.se/ontology#> .
@prefix cito: <http://purl.org/spar/cito/> .

q:216 a sh:SPARQLExecutable,
  sh:SPARQLSelectExecutable;
  sh:prefixes _:sparql_examples_prefixes ;
  sh:select '''PREFIX p: <http://www.wikidata.org/prop/>
PREFIX pq: <http://www.wikidata.org/prop/qualifier/>
PREFIX ps: <http://www.wikidata.org/prop/statement/>
PREFIX wd: <http://www.wikidata.org/entity/>
SELECT (STR(?year_) AS ?year) (SUM(?count_) AS ?count) WHERE {
  {
    SELECT ?year_ (COUNT(DISTINCT ?retractedArticle) AS ?count_) WHERE {
      ?retractedArticle p:P31 ?isRetractedPaperStatement .
      ?isRetractedPaperStatement ps:P31 wd:Q45182324 .
      ?isRetractedPaperStatement pq:P580 ?date .
      BIND (YEAR(?date) AS ?year_)
    }
    GROUP BY ?year_
  }
}
GROUP BY ?year_
ORDER BY DESC(?year_)
''';
  scholia:aspect scholiaAspect:Retraction-index ;
  scholia:defaultView scholiaView:BarChart ;
  rdfs:comment "Retraction-index aspect: no description given"@en ;
  schema:target <https://qlever.dev/wikidata> ;
  cito:usesMethodIn <https://github.com/WDscholia/scholia/tree/master/scholia/app/templates/retraction-index_retractions-per-year.sparql> ;
  dcterms:license <https://www.gnu.org/licenses/gpl-3.0> .